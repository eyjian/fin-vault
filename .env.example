# FinVault 后端环境变量模板
#
# 使用方法：
#   1. cp .env.example .env
#   2. 把下面的 sk-xxx 替换为你自己申请的真实 key
#   3. source .env  （或者用 direnv / dotenv 自动加载）
#   4. cd backend && go run ./cmd/server
#
# 注意：
#   - .env 文件已加入 .gitignore，绝对不要提交真实 key 到仓库
#   - 任何 provider 的 api_key 在 config.yaml 中通过 ${XXX_API_KEY:} 占位符读取
#   - 同时支持 FINVAULT_* 前缀的环境变量覆盖任意配置项（viper 自带机制）

# ===== LLM Provider API Keys =====
# DeepSeek：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 GLM：https://open.bigmodel.cn/usercenter/apikeys （glm-4-flash 完全免费）
GLM_API_KEY=

# Moonshot Kimi：https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=

# 阿里云通义千问：https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=

# Ollama 本地服务一般不需要 key
OLLAMA_API_KEY=

# ===== JWT =====
# 第二阶段启用认证时使用，建议设为长随机串
JWT_SECRET=change-me-to-a-long-random-string
